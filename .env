# ── Copy this file to .env and fill in your values ──────
# Never commit .env to git.

# PostgreSQL connection string
# Local:      postgres://user:password@localhost:5432/agrichain
# Production: provided by Render / Railway / Supabase
DATABASE_URL=postgres://postgres:abaa123@localhost:5432/agrichain

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=fbaa9a5e8fdcdc21cb3b87e2e97ab18ece5623536d7349265788e9bdb79376eca14bf683038ecd6441c442587496009e
# 'development' or 'production'
NODE_ENV=development

# Your frontend URL (for CORS). Use * during dev.
FRONTEND_URL=http://localhost:5500

# Server port (Render sets this automatically)
PORT=3000
